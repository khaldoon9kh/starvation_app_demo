{
  "expo": {
    "name": "GRC Starvation Toolkit",
    "slug": "grc-starvation-toolkit",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/images/icon-1024.png",
    "splash": {
      "image": "./assets/images/image.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/29211090-5cd9-4311-997d-0197004a6bf7"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.grc.starvation.toolkit",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to save diagrams and templates.",
        "NSPhotoLibraryAddUsageDescription": "This app needs permission to save images to your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.grc.starvation.toolkit",
      "versionCode": 2,
      "permissions": [
        "WRITE_EXTERNAL_STORAGE"
      ],
      "blockedPermissions": [
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_MEDIA_AUDIO",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "newArchEnabled": true,
    "extra": {
      "eas": {
        "projectId": "29211090-5cd9-4311-997d-0197004a6bf7"
      }
    },
    "owner": "khaldoon9kh9",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-localization",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to save diagrams and templates to your photo library.",
          "savePhotosPermission": "Allow $(PRODUCT_NAME) to save diagrams and templates to your photo library.",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ]
  }
}
